{
  "__inputs": [],
  "__requires": [],
  "title": "RAG Pipeline Overview",
  "uid": "rag-pipeline-overview",
  "version": 1,
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "tags": ["rag", "pipeline"],
  "panels": [
    {
      "title": "Pipeline Step Duration (p50)",
      "type": "bargauge",
      "id": 1,
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(rag_pipeline_step_duration_seconds_bucket[$__rate_interval])) by (le, step))",
          "legendFormat": "{{step}}",
          "intervalFactor": 2
        }
      ],
      "options": {
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "continuous-Blues"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 5},
              {"color": "red", "value": 30}
            ]
          }
        }
      }
    },
    {
      "title": "Pipeline Step Duration (p95)",
      "type": "bargauge",
      "id": 2,
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_pipeline_step_duration_seconds_bucket[$__rate_interval])) by (le, step))",
          "legendFormat": "{{step}}",
          "intervalFactor": 2
        }
      ],
      "options": {
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "continuous-RdYlGr"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 10},
              {"color": "red", "value": 60}
            ]
          }
        }
      }
    },
    {
      "title": "Step Duration Over Time",
      "type": "timeseries",
      "id": 3,
      "gridPos": {"h": 8, "w": 12, "x": 16, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_pipeline_step_duration_seconds_bucket[$__rate_interval])) by (le, step, profile))",
          "legendFormat": "{{step}} ({{profile}})",
          "intervalFactor": 2
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "Quality Score Distribution",
      "type": "heatmap",
      "id": 4,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum(increase(rag_engine_quality_score_bucket[$__rate_interval])) by (le, engine)",
          "legendFormat": "{{engine}}",
          "intervalFactor": 2
        }
      ],
      "heatmap": {},
      "tooltip": {"show": true, "showHistogram": true}
    },
    {
      "title": "Profile Selections",
      "type": "barchart",
      "id": 5,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "sum(rag_profile_selected_total) by (profile, reason)",
          "legendFormat": "{{profile}} ({{reason}})",
          "intervalFactor": 2
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "title": "LLM Calls by Provider",
      "type": "timeseries",
      "id": 6,
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "rate(rag_llm_calls_total[$__rate_interval])",
          "legendFormat": "{{provider}} ({{status}})",
          "intervalFactor": 2
        }
      ]
    },
    {
      "title": "LLM Duration (p95)",
      "type": "timeseries",
      "id": 7,
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_llm_duration_seconds_bucket[$__rate_interval])) by (le, provider))",
          "legendFormat": "{{provider}}",
          "intervalFactor": 2
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "Cache Hit Ratio",
      "type": "stat",
      "id": 8,
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 16},
      "targets": [
        {
          "expr": "rate(rag_cache_hits_total[$__rate_interval]) / (rate(rag_cache_hits_total[$__rate_interval]) + rate(rag_cache_misses_total[$__rate_interval])) * 100",
          "legendFormat": "Hit ratio",
          "intervalFactor": 2
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 50},
              {"color": "green", "value": 80}
            ]
          }
        }
      }
    },
    {
      "title": "Cache Entries",
      "type": "stat",
      "id": 9,
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 16},
      "targets": [
        {
          "expr": "rag_cache_entries_total",
          "legendFormat": "Entries",
          "intervalFactor": 2
        }
      ]
    },
    {
      "title": "Reranker Score Distribution",
      "type": "histogram",
      "id": 10,
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 24},
      "targets": [
        {
          "expr": "sum(increase(rag_rerank_score_bucket[$__rate_interval])) by (le)",
          "legendFormat": "Rerank score",
          "intervalFactor": 2
        }
      ],
      "options": {
        "bucketOffset": 0
      }
    },
    {
      "title": "Ingestion Rate",
      "type": "timeseries",
      "id": 11,
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 24},
      "targets": [
        {
          "expr": "rate(rag_ingest_documents_total[$__rate_interval])",
          "legendFormat": "{{profile}} ({{status}})",
          "intervalFactor": 2
        }
      ]
    },
    {
      "title": "HTTP Requests by Endpoint",
      "type": "timeseries",
      "id": 12,
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 24},
      "targets": [
        {
          "expr": "rate(rag_http_requests_total[$__rate_interval])",
          "legendFormat": "{{endpoint}} ({{status}})",
          "intervalFactor": 2
        }
      ]
    },
    {
      "title": "Ingestion Duration (p95 by profile)",
      "type": "bargauge",
      "id": 13,
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 32},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_ingest_duration_seconds_bucket[$__rate_interval])) by (le, profile))",
          "legendFormat": "{{profile}}",
          "intervalFactor": 2
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "continuous-Blues"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 30},
              {"color": "red", "value": 120}
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "title": "Documents in Vector Store",
      "type": "stat",
      "id": 14,
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 32},
      "targets": [
        {
          "expr": "rag_vector_store_documents_total",
          "legendFormat": "Documents",
          "intervalFactor": 2
        }
      ]
    },
    {
      "title": "Rate Limit Hits",
      "type": "timeseries",
      "id": 15,
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 32},
      "targets": [
        {
          "expr": "rate(rag_rate_limit_hits_total[$__rate_interval])",
          "legendFormat": "{{endpoint}}",
          "intervalFactor": 2
        }
      ]
    }
  ]
}
