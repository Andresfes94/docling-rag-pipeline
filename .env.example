# RAG Pipeline — Environment Configuration
# Copy this file to .env and fill in your values.

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

# --- Authentication ---
# Single key (MVP) or comma-separated keys (multi-tenant).
# Leave empty to disable auth.
API_KEY=
API_KEYS=

# --- Storage ---
CHROMA_PERSIST_DIR=data/chroma
OUTPUT_DIR=data/output
PROFILES_PATH=profiles.yaml

# --- Embedding ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Chunking ---
CHUNK_MAX_TOKENS=512

# --- LLM ---
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234

# --- Redis (optional) ---
# Set to enable Redis-backed task state, rate limiter, and cache.
REDIS_URL=

# --- Observability ---
LOG_LEVEL=INFO
LOG_FORMAT=text

# --- Cache ---
CACHE_CAPACITY=1024
CACHE_TTL=300

# --- Quality / Evaluation ---
EVALUATOR_SCRIPT=scripts/docling-evaluate.py
